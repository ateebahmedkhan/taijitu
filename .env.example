# ── TAIJITU CONFIGURATION ──────────────────────────────

# Telegram — Get from @BotFather on Telegram
TELEGRAM_ALERT_TOKEN=your_alert_bot_token_here
TELEGRAM_COMMAND_TOKEN=your_command_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here

# Ollama — Local AI (no API key needed)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# Database
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=taijitu
POSTGRES_USER=taijitu
POSTGRES_PASSWORD=change_this_password

# Redis
REDIS_URL=redis://redis:6379/0

# App
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change_this_to_random_string